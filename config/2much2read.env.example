# 2much2read runtime settings
APP_ENV=production
LOG_LEVEL=INFO
# Maximum messages across all enabled sources in one run.
GMAIL_MAX_MESSAGES_PER_RUN=50
GMAIL_LOOKBACK_DAYS=7
GMAIL_OAUTH_CALLBACK_PORT=8765
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=16384
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=10m
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=2much2read
DIGEST_LANGUAGE=zh-TW
DIGEST_TIMEZONE=America/Montreal
DIGEST_SCHEDULE_TIME=08:00
DIGEST_SCHEDULE_TIMEZONE=America/Montreal
DIGEST_MAX_ITEMS=10
DIGEST_TOP_ITEMS=5
