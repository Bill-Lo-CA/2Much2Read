APP_ENV=development
LOG_LEVEL=INFO
GMAIL_CREDENTIALS_PATH=${HOME}/.config/newsletter-digest/google-client-secret.json
GMAIL_TOKEN_PATH=${HOME}/.config/newsletter-digest/google-token.json
GMAIL_MAX_MESSAGES_PER_RUN=50
GMAIL_LOOKBACK_DAYS=7
GMAIL_OAUTH_CALLBACK_PORT=8765
SOURCES_CONFIG_PATH=${HOME}/.config/newsletter-digest/sources.yaml
DATABASE_PATH=${HOME}/.local/share/newsletter-digest/newsletter-digest.sqlite3
LOCK_PATH=${HOME}/.local/share/newsletter-digest/newsletter-digest.lock
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_NUM_CTX=16384
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=10m
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=Newsletter Digest
DIGEST_LANGUAGE=zh-TW
DIGEST_TIMEZONE=America/Montreal
DIGEST_MAX_ITEMS=10
DIGEST_TOP_ITEMS=5
